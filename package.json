{
  "name": "plotive",
  "version": "0.1.1",
  "keywords": ["plotting", "visualization", "charts", "graphs"],
  "author": "Rémi Thebault",
  "description": "A library for plotting data.",
  "scripts": {
    "build:wasm:web": "wasm-pack build plotive-wasm --target web --out-dir ../src/wasm",
    "build:wasm:node": "wasm-pack build plotive-wasm --target nodejs --out-dir ../src/wasm-node",
    "build:wasm": "pnpm run build:wasm:web && pnpm run build:wasm:node",
    "build:ts:esm": "tsc -p tsconfig.esm.json",
    "build:ts:cjs": "tsc -p tsconfig.cjs.json",
    "build:ts": "pnpm run build:ts:esm && pnpm run build:ts:cjs",
    "clean:dist": "node scripts/clean-dist.mjs",
    "copy:wasm": "node scripts/copy-wasm.mjs",
    "copy:wasm:node": "node scripts/copy-wasm-node.mjs",
    "rename:esm": "node scripts/rename-esm-to-mjs.mjs",
    "build": "pnpm run clean:dist && pnpm run build:wasm:web && pnpm run build:ts && pnpm run copy:wasm && pnpm run build:wasm:node && pnpm run copy:wasm:node && pnpm run rename:esm",
    "prepublishOnly": "pnpm run build",
    "pack:check": "pnpm run build && npm pack --dry-run",
    "dev": "vite",
    "example:install": "pnpm --dir examples/sine install",
    "example:dev": "pnpm run build && pnpm run example:install && pnpm --dir examples/sine run dev",
    "example:build": "pnpm run build && pnpm run example:install && pnpm --dir examples/sine run build"
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}

